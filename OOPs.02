package com.tap;

class Pen {
	String color;
	String type;

	public void write() {
		System.out.println("Writing something");
	}

	public void printColor() {
		System.out.println(this.color);
	}
}

class Student {
	String name;
	int age;

	public void printInfo() {
		System.out.println(this.name);
		System.out.println(this.age);
	}

}

public class OOPs02 {

	public static void main(String[] args) {
		Pen pen1 = new Pen();
		pen1.color = "blue";
		pen1.type = "gel";

		Pen pen2 = new Pen();
		pen2.color = "Black";
		pen2.type = "Ballpoint";

		pen1.write();
		pen2.printColor();

		Student s1 = new Student();
		s1.name = "Wasim";
		s1.age = 24;

		s1.printInfo();

	}

}
